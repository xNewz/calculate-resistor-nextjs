datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  LEARNER
  TEACHER
  ADMIN
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  password          String?      // Optional for Google OAuth users
  name              String
  googleId          String?      @unique
  image             String?      @db.Text
  emailVerified     DateTime?
  role              Role         @default(LEARNER)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  lastActive        DateTime     @default(now())
  classroomsCreated Classroom[]  @relation("TeacherClassrooms")
  enrollments       Enrollment[]
  submissions       Submission[]
  systemLogs        SystemLog[]
  examViolations    ExamViolation[]
  bannedIPs         BannedIP[]
}

model Classroom {
  id          String       @id @default(uuid())
  code        String       @unique // unique invite code (e.g. 6 chars uppercase)
  name        String
  description String?      @db.Text
  teacherId   String
  teacher     User         @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  classroomId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, classroomId])
}

model Assignment {
  id            String       @id @default(uuid())
  title         String
  description   String?      @db.Text
  bandType      String       // "4" or "5"
  assignmentType String      @default("RESISTOR") // "RESISTOR" or "MULTIMETER"
  questionCount Int
  dueDate       DateTime?
  allowLate     Boolean      @default(true)
  
  // Exam Mode Additions
  isExam        Boolean      @default(false)
  timeLimit     Int?         // in minutes
  allowMobile   Boolean      @default(true)
  showSolutions Boolean      @default(false)
  questionMode  String       @default("INPUT") // "INPUT" or "CHOICE"

  multimeterMode String      @default("ALL") // "ALL", "V", "I", "R"


  classroomId   String
  classroom     Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissions   Submission[]
  violations    ExamViolation[]
}

model Submission {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score        Int
  answers      Json       // Store details of each question and student answer
  
  // Anti-cheat metrics
  violationCount   Int       @default(0)
  isAutoSubmitted  Boolean   @default(false)
  
  createdAt    DateTime   @default(now())
  completedAt  DateTime   @default(now())
}

model ExamViolation {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  type         String     // e.g. "TAB_SWITCH", "FULLSCREEN_EXIT"
  details      String?    @db.Text
  createdAt    DateTime   @default(now())
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "CREATE_CLASSROOM", "SUBMIT_QUIZ"
  status    String   // "SUCCESS" or "ERROR"
  details   String   @db.Text
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model SystemSetting {
  id                  String   @id @default("global") // Enforce single row
  maintenanceMode     Boolean  @default(false)
  announcementText    String?  @db.Text
  announcementEnabled Boolean  @default(false)
  announcementType    String   @default("INFO") // INFO, WARNING, ERROR, SUCCESS
  updatedAt           DateTime @updatedAt
}

model BannedIP {
  ip          String    @id
  reason      String    // e.g. "SYSTEM_BRUTE_FORCE", "MANUAL_BAN"
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // null for permanent ban
  bannedById  String?   // User id of admin who banned, null if system
  bannedBy    User?     @relation(fields: [bannedById], references: [id], onDelete: SetNull)
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String   // Email address
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}
